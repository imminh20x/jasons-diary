# Supabase — copy to .env and fill in real values from:
# Dashboard → Project Settings → API → Project URL & anon public key
#
# While placeholders remain, the app runs in Mock Mode (localStorage, no Supabase).

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-api-key

# Public contact & social links (safe to customize per deployment; keep real values in .env only)
VITE_CONTACT_EMAIL=you@example.com
VITE_CONTACT_PHONE=+10000000000
VITE_GITHUB_URL=https://github.com/your-username
VITE_LINKEDIN_URL=https://linkedin.com/in/your-username
VITE_FACEBOOK_URL=

# Setup checklist:
# 1. Create a project at https://supabase.com
# 2. Edit supabase/schema.sql → replace REPLACE_WITH_ADMIN_EMAIL with your admin email
# 3. Run supabase/schema.sql in SQL Editor
# 4. Run supabase/storage.sql in SQL Editor
# 5. Auth → Users → Add user (admin login for /admin)
# 6. Paste URL + anon key above, then: npm run check:supabase
# 7. Restart: npm run dev
