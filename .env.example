# Supabase — copy to .env and fill in real values from:
# Dashboard → Project Settings → API → Project URL & anon public key
#
# While placeholders remain, the app runs in Mock Mode (localStorage, no Supabase).

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-api-key

# Setup checklist:
# 1. Create a project at https://supabase.com
# 2. Run supabase/schema.sql in SQL Editor
# 3. Run supabase/storage.sql in SQL Editor
# 4. Auth → Users → Add user (admin login for /admin)
# 5. Paste URL + anon key above, then: npm run check:supabase
# 6. Restart: npm run dev
